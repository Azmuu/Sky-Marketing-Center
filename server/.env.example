# Port for the API server (default: 3001)
PORT=3001

# Email where contact form messages are sent (service provider)
PROVIDER_EMAIL=skymarketingcenter@gmail.com

# SMTP (e.g. Gmail, SendGrid, Mailgun). If not set, contact form will fail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Sky Marketing Center <your-smtp-email@gmail.com>
